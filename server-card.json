{
  "name": "sregymgate",
  "title": "SREGym Incident Replay Gate",
  "description": "A paid remote MCP for SREGym, built to return verdicts, receipts, usage logs, and audit-ready JSON for agent and CI workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://sregymgate.clauxel.com/",
  "documentationUrl": "https://sregymgate.clauxel.com/mcp/",
  "endpointUrl": "https://sregymgate.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://sregymgate.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://sregymgate.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://sregymgate.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "lab",
        "name": "Lab",
        "monthlyUsd": 69
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 219
      },
      {
        "id": "ops",
        "name": "Ops",
        "monthlyUsd": 699
      }
    ]
  },
  "tools": [
    {
      "name": "run_incident_replay",
      "description": "SREGym Incident Replay Gate run incident replay",
      "inputSchema": {
        "type": "object",
        "properties": {
          "sample": {
            "type": "string",
            "description": "Workflow sample, schema, policy fixture, or agent output."
          },
          "context": {
            "type": "string",
            "description": "Optional review context."
          }
        },
        "required": [
          "sample"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "verdict": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "receipt_id": {
            "type": "string"
          },
          "usage_units": {
